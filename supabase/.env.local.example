# Supabase Edge Functions — local dev environment
# Copy to .env.local and fill in values from `supabase status` output

# Secrets bellow are auto-injected when using `supabase functions serve`, but can be overridden here if needed
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<anon key from `supabase status`>
SUPABASE_SERVICE_ROLE_KEY=<service_role key from `supabase status`>
